# Herald CLI — Environment Configuration
# Copy to .env and fill in your values.
# Alternatively, use ~/.config/herald/config.toml (run: herald config init)

# ─── Server ─────────────────────────────────────────────────────────
HERALD_SERVER_URL=https://mail.example.com

# ─── Auth Method ────────────────────────────────────────────────────
# Options: app-password, api-key, oauth-browser, oauth-device
HERALD_AUTH_METHOD=app-password

# ─── App Password (method=app-password) ────────────────────────────
HERALD_USERNAME=you@example.com
HERALD_PASSWORD=your-app-password-here

# ─── API Key (method=api-key) ──────────────────────────────────────
# HERALD_API_KEY=your-api-key-here

# ─── OAuth (method=oauth-browser or oauth-device) ──────────────────
# HERALD_CLIENT_ID=herald

# ─── Sender Info ───────────────────────────────────────────────────
HERALD_FROM_EMAIL=you@example.com
HERALD_FROM_NAME=Your Name
